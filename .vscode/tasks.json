{
	"tasks": [
		{
			"label": "CMake: configure app",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--preset",
				"dev-app"
			],
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		},
		{
			"label": "CMake: build hmbook",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"build-app",
				"--target",
				"hmbook"
			],
			"dependsOn": [
				"CMake: configure app"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "Инкрементальная сборка цели hmbook в каталоге build."
		},
		{
			"label": "CMake: configure tests",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--preset",
				"dev-tests"
			],
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		},
		{
			"label": "CMake: build tests",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"build-tests"
			],
			"dependsOn": [
				"CMake: configure tests"
			],
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		},
		{
			"label": "CMake: configure parser",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--preset",
				"dev-parser"
			],
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		},
		{
			"label": "CMake: build parser utility",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"build-parser",
				"--target",
				"parser"
			],
			"dependsOn": [
				"CMake: configure parser"
			],
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		},
		{
			"type": "cppbuild",
			"label": "C/C++: g++.exe сборка активного файла",
			"command": "C:/msys64/ucrt64/bin/g++.exe",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"${file}",
				"-o",
				"${fileDirname}\\${fileBasenameNoExtension}.exe"
			],
			"options": {
				"cwd": "C:/msys64/ucrt64/bin"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "none",
			"detail": "Задача создана отладчиком."
		},
		{
			"label": "Run test_parser dump",
			"type": "shell",
			"command": ".\\build\\dev-tests\\test_parser.exe",
			"args": [],
			"dependsOn": [
				"CMake: build tests"
			],
			"isBackground": false
		},
		{
			"label": "Build test_inline_styles",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"build-tests",
				"--target",
				"test_inline_styles"
			],
			"dependsOn": [
				"CMake: configure tests"
			],
			"isBackground": false
		},
		{
			"label": "Run inline styles test",
			"type": "shell",
			"command": "ctest",
			"args": [
				"--test-dir",
				"${workspaceFolder}/build/dev-tests",
				"-R",
				"parser_inline_styles_test",
				"--output-on-failure"
			],
			"dependsOn": [
				"Build test_inline_styles"
			],
			"isBackground": false
		}
	],
	"version": "2.0.0"
}