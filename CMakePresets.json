{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base-debug",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "dev-app",
      "inherits": "base-debug",
      "displayName": "Dev: App",
      "description": "Сборка только GUI-приложения mdbook",
      "cacheVariables": {
        "MDBOOK_BUILD_APP": "ON",
        "MDBOOK_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "dev-tests",
      "inherits": "base-debug",
      "displayName": "Dev: Tests",
      "description": "Сборка только тестовых утилит из tests",
      "cacheVariables": {
        "MDBOOK_BUILD_APP": "OFF",
        "MDBOOK_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "dev-all",
      "inherits": "base-debug",
      "displayName": "Dev: All",
      "description": "Сборка приложения и тестов",
      "cacheVariables": {
        "MDBOOK_BUILD_APP": "ON",
        "MDBOOK_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-app",
      "configurePreset": "dev-app"
    },
    {
      "name": "build-tests",
      "configurePreset": "dev-tests"
    },
    {
      "name": "build-all",
      "configurePreset": "dev-all"
    }
  ]
}
